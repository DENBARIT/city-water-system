generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================
// ENUMS
// =========================
enum UserRole {
  CUSTOMER
  FIELD_OFFICER
  SUBCITY_ADMIN
  SYSTEM_ADMIN
}

enum FieldOfficerType {
  METER_READER
  COMPLAINT_OFFICER
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// =========================
// USER MODEL
// =========================
model User {
  id String @id @default(uuid())

  fullName       String
  phoneE164      String @unique
  email          String @unique
  nationalId     String @unique
  passwordHash   String
  profileImageUrl String?

  otp       String?
  otpExpiry DateTime?
  emailVerified Boolean @default(false)

  role             UserRole
  fieldOfficerType FieldOfficerType?
  status           AccountStatus @default(ACTIVE)
  lastLoginAt      DateTime?

  subCityId String?
  subCity   SubCity? @relation(fields: [subCityId], references: [id], onDelete: Restrict)

  woredaId String?
  woreda   Woreda? @relation(fields: [woredaId], references: [id], onDelete: SetNull)

  // Relations
  meter Meter?

  meterReadingsCreated MeterReading[] @relation("MeterReadingCreatedBy")
  bills                Bill[]
  payments             Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subCityId])
  @@index([woredaId])
}

// =========================
// METER MODEL
// =========================
model Meter {
  id String @id @default(uuid())
  meterNumber String @unique

  customerId String? @unique
  customer   User? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  readings MeterReading[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =========================
// METER READING MODEL
// =========================
model MeterReading {
  id String @id @default(uuid())

  meterId String
  meter   Meter @relation(fields: [meterId], references: [id])

  readingValue Float
  readingDate  DateTime

  createdById String
  createdBy   User @relation("MeterReadingCreatedBy", fields: [createdById], references: [id])

  bills Bill[] // back-relation for Bill

  createdAt DateTime @default(now())

  @@index([meterId])
  @@index([createdById])
}

// =========================
// BILL MODEL
// =========================
model Bill {
  id String @id @default(uuid())

  customerId String
  customer   User @relation(fields: [customerId], references: [id])

  meterReadingId String
  meterReading   MeterReading @relation(fields: [meterReadingId], references: [id])

  consumption Float
  amount      Float
  status      String

  payments Payment[]

  createdAt DateTime @default(now())

  @@index([customerId])
  @@index([meterReadingId])
}

// =========================
// PAYMENT MODEL
// =========================
model Payment {
  id String @id @default(uuid())

  billId String
  bill   Bill @relation(fields: [billId], references: [id])

  userId String
  user   User @relation(fields: [userId], references: [id])

  amount Float
  paymentDate DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([billId])
  @@index([userId])
}

// =========================
// WATER TARIFF MODEL
// =========================
model Tariff {
  id String @id @default(uuid())

  pricePerCubicMeter Float
  effectiveFrom DateTime

  createdAt DateTime @default(now())
}

// =========================
// SUBCITY MODEL
// =========================
model SubCity {
  id   String @id @default(uuid())
  name String @unique

  users   User[]
  woredas Woreda[]

  createdAt DateTime @default(now())
}

// =========================
// WOREDA MODEL
// =========================
model Woreda {
  id   String @id @default(uuid())
  name String

  subCityId String
  subCity   SubCity @relation(fields: [subCityId], references: [id])

  users User[]

  @@index([subCityId])
}