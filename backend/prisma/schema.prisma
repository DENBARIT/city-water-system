generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



// =========================
// ENUMS
// =========================
enum UserRole {
  CUSTOMER
  FIELD_OFFICER
  SUBCITY_ADMIN
  SYSTEM_ADMIN
}

enum FieldOfficerType {
  METER_READER
  COMPLAINT_OFFICER
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// =========================
// USER MODEL
// =========================
model User {
  id String @id @default(uuid())

  fullName     String
  phoneE164    String @unique
  email        String @unique
  nationalId   String @unique
  passwordHash String
  profileImageUrl String?

  otp       String?
  otpExpiry DateTime?
  emailVerified Boolean  @default(false)

  role             UserRole
  fieldOfficerType FieldOfficerType?
  status           AccountStatus @default(ACTIVE)
  lastLoginAt      DateTime?

  subCityId String
  subCity   SubCity @relation(fields: [subCityId], references: [id], onDelete: Restrict)

  woredaId String?
  woreda   Woreda? @relation(fields: [woredaId], references: [id], onDelete: SetNull)

  meter Meter?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =========================
// METER MODEL
// =========================
model Meter {
  id String @id @default(uuid())
  meterNumber String @unique

  customerId String? @unique
  customer   User? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =========================
// SUBCITY MODEL
// =========================
model SubCity {
  id   String @id @default(uuid())
  name String
  users User[]
  woredas Woreda[]
}

// =========================
// WOREDA MODEL
// =========================
model Woreda {
  id        String @id @default(uuid())
  name      String

  subCityId String
  subCity   SubCity @relation(fields: [subCityId], references: [id])

  users User[]
}